# Supabase configuration.
# NEXT_PUBLIC_* values are bundled into browser code. Do not put secrets here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key is public by design. Data access must still be protected by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# MVP runtime code does not require SUPABASE_SERVICE_ROLE_KEY.
# Do not add service role keys to client-visible environments or commit them.
